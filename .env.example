# Copy this file to ".env" and fill with your Firebase Web App config.
# Get these from Firebase Console > Project Settings > Your apps > Web app.
# These are public client identifiers (safe to bundle). Data security comes
# from Firestore Security Rules (see firestore.rules), not from hiding these.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional: GitHub repo ("owner/name") for in-app update checks via Releases.
# Leave empty to use the Firestore appConfig/latest fallback instead.
EXPO_PUBLIC_GITHUB_REPO=
